# ── Application ────────────────────────────────────────────────
VYAPARI_ENV=development

# ── Database ───────────────────────────────────────────────────
# SQLite (development):
DATABASE_URL=sqlite:///./vyapari.db
# PostgreSQL (production example):
# DATABASE_URL=postgresql://user:pass@localhost:5432/vyapari

# ── Security ───────────────────────────────────────────────────
# CRITICAL: Change this to a long random secret in production!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=please-change-me-use-a-long-random-secret

JWT_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_COOKIE_NAME=refresh_token

# ── Cookie Settings ────────────────────────────────────────────
# lax (development/same-origin), strict (production), none (cross-site)
AUTH_COOKIE_SAMESITE=lax
# Set to true in production with HTTPS
AUTH_COOKIE_SECURE=false

# ── CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ── External APIs (optional) ───────────────────────────────────
OPENAI_API_KEY=
REVIEW_RESPONSE_MAX_WORDS=60

# ── Frontend (Vite build) ──────────────────────────────────────
# Used when building Docker image; set to your backend URL in production
VITE_API_BASE=
