# Auto detect text files and perform LF normalization
* text=auto

# Explicitly use LF for these file types (cross-platform consistency)
*.py    text eol=lf
*.jsx   text eol=lf
*.js    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf
*.ini   text eol=lf
*.sh    text eol=lf

# Binary files
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
